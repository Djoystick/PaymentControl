# Frontend (safe to expose in browser via NEXT_PUBLIC_)
NEXT_PUBLIC_APP_NAME=Payment Control
NEXT_PUBLIC_APP_STAGE=production
# Use relative API base in Vercel/production. Keep "/api" unless you really need custom routing.
NEXT_PUBLIC_API_BASE_URL=/api
# Bot username only (without @), e.g. Payment_control_center_bot
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=replace-with-bot-username

# Telegram Mini App analytics (optional for local dev; required for production analytics collection).
# Get values in TON Builders / @DataChief_bot as described in Telegram Analytics docs.
NEXT_PUBLIC_TELEGRAM_ANALYTICS_TOKEN=
NEXT_PUBLIC_TELEGRAM_ANALYTICS_APP_NAME=
# Optional: STG or PROD. Leave empty to use SDK default (PROD).
NEXT_PUBLIC_TELEGRAM_ANALYTICS_ENV=
NEXT_PUBLIC_SUPABASE_URL=https://replace-with-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-supabase-anon-key
# Donation support rails (external, no in-app payment processing).
# Keep Boosty as the primary active rail URL.
# `NEXT_PUBLIC_SUPPORT_PROJECT_URL` remains a legacy fallback for old builds and should stay Boosty-aligned.
NEXT_PUBLIC_SUPPORT_PROJECT_URL=https://boosty.to/tvoy_kosmonavt/posts/cf4114af-41b0-4a6e-b944-be6ded323c21
NEXT_PUBLIC_SUPPORT_BOOSTY_URL=https://boosty.to/tvoy_kosmonavt/posts/cf4114af-41b0-4a6e-b944-be6ded323c21
# Optional secondary rail slot (CloudTips).
# Keep empty until CloudTips URL is approved.
# Invalid or duplicate URL values are ignored and the slot stays in pending setup state.
NEXT_PUBLIC_SUPPORT_CLOUDTIPS_URL=

# Backend / server-only (never expose to browser)
SUPABASE_URL=https://replace-with-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key
SUPABASE_JWT_SECRET=replace-with-supabase-jwt-secret
TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token
TELEGRAM_BOT_API_BASE_URL=https://api.telegram.org
TELEGRAM_INIT_DATA_MAX_AGE_SEC=86400
REMINDER_SCHEDULED_DISPATCH_SECRET=replace-with-long-random-secret
CRON_SECRET=replace-with-long-random-secret
# Telegram numeric chat/user id that receives in-app bug reports from users.
BUG_REPORT_TELEGRAM_CHAT_ID=
# Comma-separated Telegram numeric user ids allowed to manage supporter badges.
# Example: 123456789,987654321
SUPPORTER_BADGE_OWNER_TELEGRAM_USER_IDS=
# Optional travel receipt OCR provider setup (server-side).
# If API key is empty, receipt drafts still save, but OCR parse actions return
# "OCR assistant is not configured on server..." fallback and can be retried later.
TRAVEL_RECEIPT_OCR_OPENAI_API_KEY=
TRAVEL_RECEIPT_OCR_OPENAI_MODEL=gpt-4o-mini

# Optional local browser fallback (development only)
# Keep disabled in production. Enable only for local manual testing outside Telegram.
ALLOW_DEV_TELEGRAM_AUTH_FALLBACK=false
DEV_TELEGRAM_USER_ID=
DEV_TELEGRAM_USERNAME=
DEV_TELEGRAM_FIRST_NAME=
DEV_TELEGRAM_LAST_NAME=
DEV_TELEGRAM_PHOTO_URL=
